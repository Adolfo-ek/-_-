import tkinter as tk
from tkinter import messagebox


class Cola:

    def __init__(self, MAX):
        self.MAX = MAX
        self.frente = 0
        self.final = 0
        self.datos = [None]*MAX

    def vacia(self):
        return self.frente == self.final

    def llena(self):
        return self.final == self.MAX

    def encolar(self, valor):
        if not self.llena():
            self.datos[self.final] = valor
            self.final += 1

    def desencolar(self):
        if not self.vacia():
            valor = self.datos[self.frente]
            self.frente += 1
            return valor


MAX = 100

colas = {
    1: Cola(MAX),
    2: Cola(MAX),
    3: Cola(MAX)
}

turnos = {
    1: 0,
    2: 0,
    3: 0
}


def dibujar():

    canvas.delete("all")

    posiciones = [150,350,550]

    for i, servicio in enumerate(colas):

        x = posiciones[i]

        canvas.create_text(x,40,text=f"Servicio {servicio}",font=("Arial",12,"bold"))

        y = 80

        cola = colas[servicio]

        for j in range(cola.frente, cola.final):

            turno = cola.datos[j]

            canvas.create_rectangle(x-40,y,x+40,y+30,fill="#87CEFA")

            canvas.create_text(x,y+15,text=turno)

            y += 40


def llegada_cliente():

    try:

        servicio = int(entrada_servicio.get())

        if servicio not in colas:
            messagebox.showerror("Error","Servicio no válido")
            return

        turnos[servicio] += 1

        turno = f"S{servicio}-{turnos[servicio]}"

        colas[servicio].encolar(turno)

        salida.config(text=f"Turno generado: {turno}")

        dibujar()

    except:
        messagebox.showerror("Error","Ingresa un servicio válido")


def atender_cliente():

    try:

        servicio = int(entrada_servicio.get())

        if servicio not in colas:
            messagebox.showerror("Error","Servicio no válido")
            return

        if colas[servicio].vacia():

            salida.config(text="No hay clientes en la cola")

        else:

            turno = colas[servicio].desencolar()

            salida.config(text=f"Atendiendo: {turno}")

        dibujar()

    except:
        messagebox.showerror("Error","Ingresa un servicio válido")


ventana = tk.Tk()
ventana.title("Sistema de Colas - Compañía de Seguros")
ventana.geometry("700x450")


titulo = tk.Label(
    ventana,
    text="Sistema de Atención de Clientes",
    font=("Arial",16,"bold")
)

titulo.pack(pady=10)


frame = tk.Frame(ventana)
frame.pack()


tk.Label(frame,text="Servicio (1-3):").grid(row=0,column=0,padx=5)

entrada_servicio = tk.Entry(frame,width=5)
entrada_servicio.grid(row=0,column=1,padx=5)


btn_llegada = tk.Button(
    frame,
    text="Llegada Cliente (C)",
    command=llegada_cliente,
    width=18
)

btn_llegada.grid(row=0,column=2,padx=5)


btn_atender = tk.Button(
    frame,
    text="Atender Cliente (A)",
    command=atender_cliente,
    width=18
)

btn_atender.grid(row=0,column=3,padx=5)


canvas = tk.Canvas(
    ventana,
    width=650,
    height=300,
    bg="white"
)

canvas.pack(pady=20)


salida = tk.Label(
    ventana,
    text="",
    font=("Arial",12,"bold")
)

salida.pack()


dibujar()

ventana.mainloop()
