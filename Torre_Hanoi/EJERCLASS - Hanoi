import time

class Pila:

    def __init__(self, MAX):
        self.MAX = MAX
        self.TOPE = 0
        self.Datos = [0]*MAX

    def Pila_vacia(self):
        return self.TOPE == 0

    def Pila_llena(self):
        return self.TOPE == self.MAX

    def Pone(self, argumento):
        if not self.Pila_llena():
            self.Datos[self.TOPE] = argumento
            self.TOPE = self.TOPE + 1

    def Quita(self):
        if not self.Pila_vacia():
            self.TOPE = self.TOPE - 1
            return self.Datos[self.TOPE]


def mover_disco(origen, destino):
    disco = origen.Quita()
    destino.Pone(disco)
    print("Mover disco", disco)


def hanoi(n, origen, auxiliar, destino):
    if n == 1:
        mover_disco(origen, destino)
    else:
        hanoi(n-1, origen, destino, auxiliar)
        mover_disco(origen, destino)
        hanoi(n-1, auxiliar, origen, destino)


n = int(input("Numero de discos: "))

A = Pila(n)
B = Pila(n)
C = Pila(n)

for i in range(n,0,-1):
    A.Pone(i)

inicio = time.time()

hanoi(n,A,B,C)

fin = time.time()

print("Tiempo de ejecucion:", fin - inicio, "segundos")
print("Movimientos teoricos:", 2**n - 1)
